# ─────────────────────────────────────────
# HSC AI Platform — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Application
APP_VERSION=0.1.0
APP_URL=http://localhost:3090
DEBUG=true

# ── PostgreSQL ────────────────────────────
POSTGRES_USER=hscai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=hscai
# Internal endpoint (inside Docker containers)
DATABASE_URL=postgresql+asyncpg://hscai:change_me_in_production@postgres:5432/hscai
# Host-side endpoint (port 5435 mapped in docker-compose; used by alembic and pytest on host)
ALEMBIC_DATABASE_URL=postgresql+asyncpg://hscai:change_me_in_production@localhost:5435/hscai
# Test database — Docker-internal address (used by docker compose exec backend python -m pytest)
TEST_DATABASE_URL=postgresql+asyncpg://hscai:change_me_in_production@postgres:5432/hscai_test
# Optional host-side test URL for local pytest (uncomment if running pytest on the host):
# TEST_DATABASE_URL=postgresql+asyncpg://hscai:change_me_in_production@localhost:5435/hscai_test

# ── Redis ─────────────────────────────────
# Internal Docker network only — not exposed to host
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────
# Internal endpoint used by the backend service
MINIO_ENDPOINT=minio:9000
# Public endpoints accessible from the host machine
MINIO_PUBLIC_ENDPOINT=http://localhost:9190
MINIO_CONSOLE_URL=http://localhost:9191
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=hscai
MINIO_SECURE=false

# ── CORS ──────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3090,http://localhost:3091

# ── Next.js ───────────────────────────────
# Accessed from the browser through nginx — use the nginx host port
NEXT_PUBLIC_API_URL=http://localhost:3090/api

# ── AI Providers ──────────────────────────
# OpenAI (GPT-4o-mini)
# OPENAI_API_KEY=sk-...
# Anthropic Claude (Sonnet 4)
# ANTHROPIC_API_KEY=sk-ant-...
# DeepSeek
# DEEPSEEK_API_KEY=sk-...
# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
