# ─────────────────────────────────────────
# HSC AI Platform — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Application
APP_VERSION=0.1.0
DEBUG=true

# ── PostgreSQL ────────────────────────────
POSTGRES_USER=hscai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=hscai
# Used by FastAPI backend (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://hscai:change_me_in_production@postgres:5432/hscai

# ── Redis ─────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=hscai
MINIO_SECURE=false

# ── CORS ──────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Next.js ───────────────────────────────
# Public URL of the FastAPI backend (accessible from the browser)
NEXT_PUBLIC_API_URL=http://localhost:80/api
